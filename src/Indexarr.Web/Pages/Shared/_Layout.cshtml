<!DOCTYPE html>
@using Indexarr.Web.Localization
@inject Indexarr.Web.Services.AutomationRuntimeState AutomationRuntime
@{
    var currentLanguage = (string?)ViewData["CurrentLanguage"] ?? "it";
    string T(string key) => UiTextCatalog.Get(currentLanguage, key);
    (string Label, string Value) FormatAutomationMessage(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return (T("SidebarAutomationMessage"), "-");
        }

        return (T("SidebarAutomationMessage"), message);
    }

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var automationMessageInfo = AutomationRuntime.LastStartedAtUtc is null && AutomationRuntime.LastCompletedAtUtc is null
        ? (T("SidebarAutomationMessage"), T("SidebarAutomationNoRunsYet"))
        : FormatAutomationMessage(AutomationRuntime.LastMessage);
}
<html lang="@currentLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Indexarr</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="icon" type="image/png" sizes="1254x1254" href="~/images/indexarr_logo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/indexarr_logo.png" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script>
        (function () {
            var stored = localStorage.getItem('indexarr-theme') || 'system';
            var resolved = stored === 'system'
                ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                : stored;
            document.documentElement.dataset.theme = resolved;
            document.documentElement.dataset.themePreference = stored;
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Indexarr.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (currentPage == "/Login")
    {
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="app-shell">
            <header class="mobile-topbar">
                <button type="button" class="menu-toggle" id="menuToggle" aria-controls="appSidebar" aria-expanded="false" aria-label="@T("SidebarOpenMenu")">
                    <span></span><span></span><span></span>
                </button>
                <a class="mobile-brand" asp-page="/Index">
                    <img src="~/images/indexarr_logo.png" alt="" />
                    <span>Indexarr</span>
                </a>
                <span class="mobile-brand-spacer" aria-hidden="true"></span>
            </header>
            <div class="sidebar-backdrop" id="sidebarBackdrop" hidden></div>
            <aside class="app-sidebar" id="appSidebar" aria-label="@T("SidebarNav")">
                <button type="button" class="sidebar-close" id="sidebarClose" aria-label="@T("SidebarCloseMenu")">×</button>
                <div class="sidebar-brand">
                    <span class="brand-logo-wrap">
                        <img src="~/images/indexarr_logo.png" alt="" class="brand-logo" />
                    </span>
                    <a class="sidebar-title" asp-page="/Index">Indexarr</a>
                    <div class="sidebar-brand-actions">
                        <span class="brand-live-dot" title="@T("SidebarPollingActive")"></span>
                        <button type="button" class="theme-toggle" id="themeToggle" data-role="theme-toggle"
                                data-label-dark="@T("ThemeToggleToDark")"
                                data-label-light="@T("ThemeToggleToLight")"
                                data-label-system="@T("ThemeToggleToSystem")"
                                aria-label="@T("ThemeToggleToLight")">
                            <svg class="theme-toggle-icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="4"></circle>
                                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
                            </svg>
                            <svg class="theme-toggle-icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
                            </svg>
                            <svg class="theme-toggle-icon icon-system" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                                <path d="M8 20h8M12 16v4"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <section class="sidebar-status-card">
                    <span class="sidebar-status-label">@T("SidebarAutomationTitle")</span>
                    <strong class="sidebar-status-value @(AutomationRuntime.IsRunning ? "is-running" : AutomationRuntime.IsEnabled ? "is-idle" : "is-disabled")"
                            data-role="automation-status-label">
                        @(AutomationRuntime.IsRunning
                            ? T("SidebarAutomationInProgress")
                            : AutomationRuntime.IsEnabled
                                ? T("SidebarAutomationNextRun")
                                : T("SidebarAutomationNoSchedule"))
                    </strong>
                    <div class="sidebar-automation-hero"
                         id="automationCountdown"
                         data-enabled="@AutomationRuntime.IsEnabled.ToString().ToLowerInvariant()"
                         data-running="@AutomationRuntime.IsRunning.ToString().ToLowerInvariant()"
                         data-interval-seconds="@(Math.Max(1, AutomationRuntime.IntervalMinutes) * 60)"
                         data-next-run-utc="@AutomationRuntime.NextScheduledAtUtc?.ToString("O")"
                         data-label-next="@T("SidebarAutomationNextRun")"
                         data-label-due="@T("SidebarAutomationDueNow")"
                         data-label-running="@T("SidebarAutomationInProgress")"
                         data-label-disabled="@T("SidebarAutomationNoSchedule")"
                         data-label-message="@T("SidebarAutomationMessage")"
                         data-label-indexer-state="@T("SidebarAutomationIndexerState")"
                         data-label-no-runs="@T("SidebarAutomationNoRunsYet")"
                         data-status-endpoint="/api/automation-status">
                        <div class="automation-ring">
                            <div class="automation-ring-core">
                                <span class="automation-ring-value" data-role="countdown-value">--:--</span>
                            </div>
                        </div>
                        <div class="automation-progress-track" aria-hidden="true">
                            <span class="automation-progress-bar" data-role="countdown-bar"></span>
                        </div>
                    </div>
                    <div class="config-lines">
                        <span><strong>@T("SidebarAutomationLastStart"):</strong> <span data-role="last-start">@(AutomationRuntime.LastStartedAtUtc?.ToLocalTime().ToString("g") ?? "-")</span></span>
                        <span><strong>@T("SidebarAutomationLastEnd"):</strong> <span data-role="last-end">@(AutomationRuntime.LastCompletedAtUtc?.ToLocalTime().ToString("g") ?? "-")</span></span>
                        <span><strong data-role="message-label">@(automationMessageInfo.Item1):</strong> <span data-role="message-value">@(automationMessageInfo.Item2)</span></span>
                    </div>
                </section>

                <nav class="sidebar-nav">
                    <a class="sidebar-link @(currentPage == "/Index" ? "is-active" : string.Empty)" asp-page="/Index">@T("NavDashboard")</a>
                    <a class="sidebar-link @(currentPage == "/Settings" ? "is-active" : string.Empty)" asp-page="/Settings">@T("NavSettings")</a>
                </nav>

                <div class="sidebar-auth">
                    @if (isAuthenticated)
                    {
                        <p>@User.Identity?.Name</p>
                        <form method="post" asp-page="/Login" asp-page-handler="Logout">
                            <button type="submit" class="btn btn-outline-light w-100">@T("NavLogout")</button>
                        </form>
                    }
                    else
                    {
                        <p>@T("ReadonlyDashboardNote")</p>
                        <a class="btn btn-primary w-100" asp-page="/Login" asp-route-returnUrl="@Url.Page("/Settings")">@T("NavLogin")</a>
                    }
                </div>
            </aside>

            <div class="app-main">
                <main role="main" class="app-content">
                    @RenderBody()
                </main>

                <footer class="footer text-muted">
                    <div class="container-fluid px-0">
                        @T("Footer")
                    </div>
                </footer>
            </div>
        </div>
    }

    <div class="processing-modal" id="globalBusyOverlay" aria-hidden="true">
        <div class="processing-modal-card" role="alertdialog" aria-modal="true" aria-labelledby="globalBusyTitle">
            <div class="processing-spinner"></div>
            <h2 id="globalBusyTitle">@T("BusyTitle")</h2>
            <p>@T("BusyText")</p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

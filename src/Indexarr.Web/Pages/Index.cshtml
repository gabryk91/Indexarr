@page
@using Indexarr.Web.Localization
@model IndexModel
@{
    ViewData["Title"] = UiTextCatalog.Get(Model.CurrentLanguage, "NavDashboard");
    ViewData["ProwlarrReachable"] = Model.Dashboard.Reachable;
    string T(string key) => UiTextCatalog.Get(Model.CurrentLanguage, key);
    var averageLatency = Model.Dashboard.Indexers.Where(indexer => indexer.LatencyMs > 0).Select(indexer => indexer.LatencyMs).DefaultIfEmpty().Average();
    var mutationTimeoutSeconds = Math.Clamp((Model.SetupDraft?.HealthCheckTimeoutSeconds ?? 30) * 6, 30, 300);

    static IEnumerable<int?> BuildPageNumbers(int current, int total)
    {
        if (total <= 1)
        {
            yield break;
        }

        var pages = new SortedSet<int>();
        foreach (var candidate in new[] { 1, 2, current, total - 1, total })
        {
            if (candidate >= 1 && candidate <= total)
            {
                pages.Add(candidate);
            }
        }

        int? previous = null;
        foreach (var pageNumber in pages)
        {
            if (previous.HasValue && pageNumber - previous.Value > 1)
            {
                yield return null;
            }

            yield return pageNumber;
            previous = pageNumber;
        }
    }
}

<header class="dashboard-heading">
    <div>
        <h1>Monitoraggio indexer</h1>
        <p>Panoramica operativa e stato dei tuoi indexer in tempo reale.</p>
    </div>
</header>

<div class="dashboard-toolbar">
    @if (Model.CanManage)
    {
        <form method="post" asp-page-handler="RunHealthCheck" data-long-operation="true">
            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
            <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
            <input type="hidden" name="AuditDateFilter" value="@Model.Dashboard.Filters.AuditDate" />
            <input type="hidden" name="AuditActionFilter" value="@Model.Dashboard.Filters.AuditAction" />
            <input type="hidden" name="AuditResultFilter" value="@Model.Dashboard.Filters.AuditResult" />
            <input type="hidden" name="IndexerPage" value="@Model.Dashboard.IndexerPage" />
            <input type="hidden" name="AuditPage" value="@Model.Dashboard.AuditPage" />
            <button type="submit" class="btn btn-primary">@await Html.PartialAsync("_Icon", "check-circle")@T("RunHealthCheck")</button>
        </form>
        <form method="post" asp-page-handler="RunAutoAdd" data-long-operation="true">
            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
            <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
            <input type="hidden" name="AuditDateFilter" value="@Model.Dashboard.Filters.AuditDate" />
            <input type="hidden" name="AuditActionFilter" value="@Model.Dashboard.Filters.AuditAction" />
            <input type="hidden" name="AuditResultFilter" value="@Model.Dashboard.Filters.AuditResult" />
            <input type="hidden" name="IndexerPage" value="@Model.Dashboard.IndexerPage" />
            <input type="hidden" name="AuditPage" value="@Model.Dashboard.AuditPage" />
            <button type="submit" class="btn btn-outline-light">@await Html.PartialAsync("_Icon", "plus-circle")@T("RunAutoAdd")</button>
        </form>
    }
    else
    {
        <a class="btn btn-primary" asp-page="/Login" asp-route-returnUrl="@Url.Page("/Settings")">@T("LoginToManage")</a>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <section class="flash-banner">@Model.FlashMessage</section>
}

<section class="overview-grid" aria-label="Riepilogo stato">
    <article class="overview-card overview-card-accent">
        <div class="overview-card-top"><span class="metric-icon icon-check"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 12 3.2 3.2L17.5 8" /></svg></span><span class="metric-label">Indexer operativi</span><span class="metric-trend trend-up">↗ live</span></div>
        <strong class="overview-value">@Model.Dashboard.HealthyIndexers <small>/ @Model.Dashboard.TotalIndexers</small></strong>
        <span class="overview-foot">Disponibilità complessiva <strong>@(Model.Dashboard.TotalIndexers == 0 ? 0 : Math.Round(Model.Dashboard.HealthyIndexers * 100m / Model.Dashboard.TotalIndexers, 1))%</strong></span>
    </article>
    <article class="overview-card">
        <div class="overview-card-top"><span class="metric-icon icon-danger"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8 8 8 8M16 8l-8 8" /></svg></span><span class="metric-label">In errore</span></div>
        <strong class="overview-value">@Model.Dashboard.FailedIndexers</strong>
        <span class="overview-foot overview-foot-status">@Model.Dashboard.BlockedIndexers bloccato <span aria-hidden="true">·</span> @(Math.Max(0, Model.Dashboard.TotalIndexers - Model.Dashboard.HealthyIndexers - Model.Dashboard.FailedIndexers - Model.Dashboard.BlockedIndexers)) disabilitato</span>
    </article>
    <article class="overview-card">
        <div class="overview-card-top"><span class="metric-icon icon-purple"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" /><path d="M12 4v2M12 18v2M4 12h2M18 12h2" /></svg></span><span class="metric-label">Abilitati</span></div>
        <strong class="overview-value">@Model.Dashboard.EnabledIndexers <small>/ @Model.Dashboard.TotalIndexers</small></strong>
        <span class="overview-foot">@(Model.SetupDraft?.AutoDisableFailedIndexers == true ? "Auto-disable attivo" : "Auto-disable disattivo")</span>
    </article>
    <article class="overview-card">
        <div class="overview-card-top"><span class="metric-icon icon-blue"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 14h3l2-7 4 13 2-7h5" /></svg></span><span class="metric-label">Latenza media</span></div>
        <strong class="overview-value">@(averageLatency > 0 ? Math.Round(averageLatency) : 0) <small>ms</small></strong>
        <span class="overview-foot">Media sui check disponibili</span>
    </article>
</section>

<section class="analytics-grid">
    <article class="surface-card health-chart-card">
        <div class="section-heading-row"><div><h2>Andamento salute</h2><p>Ultime 24 ore</p></div><span class="chart-score">@(Model.Dashboard.TotalIndexers == 0 ? 0 : Math.Round(Model.Dashboard.HealthyIndexers * 100m / Model.Dashboard.TotalIndexers, 1))%</span></div>
        <div class="health-chart" role="img" aria-label="Grafico andamento salute indexer">
            <div class="chart-grid-lines"><span></span><span></span><span></span><span></span></div>
            <svg viewBox="0 0 720 190" preserveAspectRatio="none" aria-hidden="true"><defs><linearGradient id="healthFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0" stop-color="#5b8cff" stop-opacity=".38"/><stop offset="1" stop-color="#5b8cff" stop-opacity="0"/></linearGradient></defs><path class="chart-area" d="M0 132 L48 110 L96 122 L144 94 L192 76 L240 110 L288 146 L336 92 L384 68 L432 54 L480 78 L528 112 L576 96 L624 74 L672 60 L720 78 L720 190 L0 190 Z"/><path class="chart-line" d="M0 132 L48 110 L96 122 L144 94 L192 76 L240 110 L288 146 L336 92 L384 68 L432 54 L480 78 L528 112 L576 96 L624 74 L672 60 L720 78"/></svg>
            <div class="chart-axis"><span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>now</span></div>
        </div>
    </article>
    <article class="surface-card state-card">
        <div class="section-heading-row"><div><h2>Stato indexer</h2><p>Distribuzione corrente</p></div></div>
        <div class="state-overview"><div class="donut-chart" style="--healthy:@(Model.Dashboard.TotalIndexers == 0 ? 0 : Model.Dashboard.HealthyIndexers * 100 / Model.Dashboard.TotalIndexers); --failed:@(Model.Dashboard.TotalIndexers == 0 ? 0 : Model.Dashboard.FailedIndexers * 100 / Model.Dashboard.TotalIndexers); --blocked:@(Model.Dashboard.TotalIndexers == 0 ? 0 : Model.Dashboard.BlockedIndexers * 100 / Model.Dashboard.TotalIndexers); --disabled:@(Model.Dashboard.TotalIndexers == 0 ? 0 : Math.Max(0, Model.Dashboard.TotalIndexers - Model.Dashboard.HealthyIndexers - Model.Dashboard.FailedIndexers - Model.Dashboard.BlockedIndexers) * 100 / Model.Dashboard.TotalIndexers)"><strong>@Model.Dashboard.TotalIndexers</strong><span>totale</span></div><div class="state-legend"><div><span class="legend-dot legend-ok"></span><span>OK</span><strong>@Model.Dashboard.HealthyIndexers</strong></div><div><span class="legend-dot legend-fail"></span><span>FAIL</span><strong>@Model.Dashboard.FailedIndexers</strong></div><div><span class="legend-dot legend-blocked"></span><span>Bloccato</span><strong>@Model.Dashboard.BlockedIndexers</strong></div><div><span class="legend-dot legend-disabled"></span><span>Disabilitato</span><strong>@(Math.Max(0, Model.Dashboard.TotalIndexers - Model.Dashboard.HealthyIndexers - Model.Dashboard.FailedIndexers - Model.Dashboard.BlockedIndexers))</strong></div></div></div>
    </article>
</section>

<section class="table-card indexer-table-card">
    <div class="table-card-header">
        <div>
            <h2>@T("IndexersTitle")</h2>
            <p class="section-description">@T("IndexersSectionDescription")</p>
        </div>
        <form method="get" class="filter-form">
            <div>
                <label for="statusFilter" class="metric-inline-label">@T("StatusFilter")</label>
                <select id="statusFilter" name="StatusFilter" class="form-select">
                    <option value="all" selected="@(Model.Dashboard.Filters.Status == "all")">@T("FilterAll")</option>
                    <option value="ok" selected="@(Model.Dashboard.Filters.Status == "ok")">OK</option>
                    <option value="fail" selected="@(Model.Dashboard.Filters.Status == "fail")">FAIL</option>
                    <option value="disabled" selected="@(Model.Dashboard.Filters.Status == "disabled")">@T("Disabled")</option>
                    <option value="blocked" selected="@(Model.Dashboard.Filters.Status == "blocked")">@T("Blocked")</option>
                </select>
            </div>
            <div>
                <label for="protocolFilter" class="metric-inline-label">@T("ProtocolFilter")</label>
                <select id="protocolFilter" name="ProtocolFilter" class="form-select">
                    <option value="all" selected="@(Model.Dashboard.Filters.Protocol == "all")">@T("FilterAll")</option>
                    @foreach (var protocol in Model.Dashboard.AvailableProtocols)
                    {
                        <option value="@protocol.ToLowerInvariant()" selected="@(Model.Dashboard.Filters.Protocol == protocol.ToLowerInvariant())">@protocol</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-outline-light">@T("ApplyFilters")</button>
        </form>
    </div>

    @if (!Model.CanManage)
    {
        <p class="table-empty">@T("ReadonlyDashboardNote") <a asp-page="/Login" asp-route-returnUrl="@Url.Page("/Settings")">@T("NavLogin")</a>.</p>
    }

    @if (Model.Dashboard.Indexers.Count == 0)
    {
        <p class="table-empty">@T("NoIndexers")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>@T("Name")</th>
                        <th>@T("Protocol")</th>
                        <th>@T("Result")</th>
                        <th>@T("Trend")</th>
                        <th>@T("Latency")</th>
                        <th>@T("LastCheck")</th>
                        <th>@T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var indexer in Model.Dashboard.Indexers)
                    {
                        var trendArrow = indexer.Trend.Equals("Up", StringComparison.OrdinalIgnoreCase) ? "↗" : indexer.Trend.Equals("Down", StringComparison.OrdinalIgnoreCase) ? "↘" : "→";
                        <tr class="indexer-row indexer-row-@indexer.Result.ToLowerInvariant()">
                            <td><span class="row-status-dot row-status-@indexer.Result.ToLowerInvariant()" aria-hidden="true"></span><span class="indexer-name">@indexer.Name</span><small class="indexer-implementation">@indexer.Implementation</small></td>
                            <td>@indexer.Protocol</td>
                            <td><span class="result-badge result-@indexer.Result.ToLowerInvariant()">@indexer.Result</span></td>
                            <td><span class="trend-badge trend-@indexer.Trend.ToLowerInvariant()"><span class="trend-arrow" aria-hidden="true">@trendArrow</span>@T($"Trend{indexer.Trend}")</span></td>
                            <td>@(indexer.LatencyMs > 0 ? $"{indexer.LatencyMs} ms" : "—")</td>
                            <td>@(indexer.LastCheckedAtUtc?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                            <td>
                                @if (Model.CanManage)
                                {
                                    <div class="indexer-action-stack">
                                        @if (indexer.IsBlocked && indexer.BlockedIndexerId.HasValue)
                                        {
                                            <form method="post" asp-page-handler="UnblockIndexer" class="inline-action-form" data-long-operation="true" data-operation-timeout-seconds="@mutationTimeoutSeconds">
                                                <input type="hidden" name="blockedIndexerId" value="@indexer.BlockedIndexerId.Value" />
                                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                                <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
                                                <input type="hidden" name="AuditDateFilter" value="@Model.Dashboard.Filters.AuditDate" />
                                                <input type="hidden" name="AuditActionFilter" value="@Model.Dashboard.Filters.AuditAction" />
                                                <input type="hidden" name="AuditResultFilter" value="@Model.Dashboard.Filters.AuditResult" />
                                                <input type="hidden" name="IndexerPage" value="@Model.Dashboard.IndexerPage" />
                                                <input type="hidden" name="AuditPage" value="@Model.Dashboard.AuditPage" />
                                                <button type="submit" class="btn btn-sm btn-warning">
                                                    @T("UnblockAction")
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="ToggleIndexer" class="inline-action-form" data-long-operation="true" data-operation-timeout-seconds="@mutationTimeoutSeconds">
                                                <input type="hidden" name="indexerId" value="@indexer.Id" />
                                                <input type="hidden" name="enabled" value="@(indexer.Enabled ? "false" : "true")" />
                                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                                <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
                                                <input type="hidden" name="AuditDateFilter" value="@Model.Dashboard.Filters.AuditDate" />
                                                <input type="hidden" name="AuditActionFilter" value="@Model.Dashboard.Filters.AuditAction" />
                                                <input type="hidden" name="AuditResultFilter" value="@Model.Dashboard.Filters.AuditResult" />
                                                <input type="hidden" name="IndexerPage" value="@Model.Dashboard.IndexerPage" />
                                                <input type="hidden" name="AuditPage" value="@Model.Dashboard.AuditPage" />
                                                <button type="submit" class="btn btn-sm @(indexer.Enabled ? "btn-outline-light" : "btn-secondary")">
                                                    @(indexer.Enabled ? T("DisableAction") : T("EnableAction"))
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="BlockIndexer" class="inline-action-form" data-long-operation="true" data-operation-timeout-seconds="@mutationTimeoutSeconds">
                                                <input type="hidden" name="indexerId" value="@indexer.Id" />
                                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                                <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
                                                <input type="hidden" name="AuditDateFilter" value="@Model.Dashboard.Filters.AuditDate" />
                                                <input type="hidden" name="AuditActionFilter" value="@Model.Dashboard.Filters.AuditAction" />
                                                <input type="hidden" name="AuditResultFilter" value="@Model.Dashboard.Filters.AuditResult" />
                                                <input type="hidden" name="IndexerPage" value="@Model.Dashboard.IndexerPage" />
                                                <input type="hidden" name="AuditPage" value="@Model.Dashboard.AuditPage" />
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    @T("BlockAction")
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="muted-chip">@T("LoginRequiredShort")</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <nav class="pagination-bar" aria-label="@T("PaginationIndexerLabel")">
            <span class="pagination-summary">@string.Format(T("PaginationSummary"), Model.Dashboard.IndexerPage, Model.Dashboard.IndexerTotalPages, Model.Dashboard.IndexerTotalCount)</span>
            <div class="pagination-actions">
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.IndexerPage <= 1 ? "disabled" : string.Empty)"
                   asp-route-indexerPage="1" asp-route-auditPage="@Model.Dashboard.AuditPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">«</a>
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.IndexerPage <= 1 ? "disabled" : string.Empty)"
                   asp-route-indexerPage="@(Math.Max(1, Model.Dashboard.IndexerPage - 1))" asp-route-auditPage="@Model.Dashboard.AuditPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">‹</a>
                @foreach (var pageNumber in BuildPageNumbers(Model.Dashboard.IndexerPage, Model.Dashboard.IndexerTotalPages))
                {
                    if (pageNumber is null)
                    {
                        <span class="pagination-ellipsis">…</span>
                    }
                    else
                    {
                        <a class="btn btn-sm pagination-page @(pageNumber == Model.Dashboard.IndexerPage ? "btn-primary" : "btn-outline-light")"
                           asp-route-indexerPage="@pageNumber" asp-route-auditPage="@Model.Dashboard.AuditPage"
                           asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                           asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">@pageNumber</a>
                    }
                }
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.IndexerPage >= Model.Dashboard.IndexerTotalPages ? "disabled" : string.Empty)"
                   asp-route-indexerPage="@(Math.Min(Model.Dashboard.IndexerTotalPages, Model.Dashboard.IndexerPage + 1))" asp-route-auditPage="@Model.Dashboard.AuditPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">›</a>
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.IndexerPage >= Model.Dashboard.IndexerTotalPages ? "disabled" : string.Empty)"
                   asp-route-indexerPage="@Model.Dashboard.IndexerTotalPages" asp-route-auditPage="@Model.Dashboard.AuditPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">»</a>
            </div>
        </nav>
    }
</section>

<section class="table-card audit-table-card">
    <div class="table-card-header">
        <div>
            <h2>@T("AuditLogTitle")</h2>
            <p class="section-description">@T("AuditLogSectionDescription")</p>
        </div>
        <form method="get" class="filter-form">
            <div>
                <label for="auditDateFilter" class="metric-inline-label">@T("AuditDateFilter")</label>
                <input id="auditDateFilter" name="AuditDateFilter" type="date" value="@Model.Dashboard.Filters.AuditDate" class="form-control" />
            </div>
            <div>
                <label for="auditActionFilter" class="metric-inline-label">@T("AuditActionFilter")</label>
                <select id="auditActionFilter" name="AuditActionFilter" class="form-select">
                    <option value="all" selected="@(Model.Dashboard.Filters.AuditAction == "all")">@T("FilterAll")</option>
                    @foreach (var action in Model.Dashboard.AvailableAuditActions)
                    {
                        <option value="@action" selected="@(Model.Dashboard.Filters.AuditAction == action)">@action</option>
                    }
                </select>
            </div>
            <div>
                <label for="auditResultFilter" class="metric-inline-label">@T("AuditResultFilter")</label>
                <select id="auditResultFilter" name="AuditResultFilter" class="form-select">
                    <option value="all" selected="@(Model.Dashboard.Filters.AuditResult == "all")">@T("FilterAll")</option>
                    <option value="ok" selected="@(Model.Dashboard.Filters.AuditResult == "ok")">OK</option>
                    <option value="fail" selected="@(Model.Dashboard.Filters.AuditResult == "fail")">FAIL</option>
                </select>
            </div>
            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
            <input type="hidden" name="ProtocolFilter" value="@Model.ProtocolFilter" />
            <button type="submit" class="btn btn-outline-light">@T("ApplyFilters")</button>
        </form>
    </div>
    @if (Model.Dashboard.AuditLogs.Count == 0)
    {
        <p class="table-empty">@T("NoAuditLogs")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark align-middle audit-table">
                <thead>
                    <tr>
                          <th>@T("When")</th>
                          <th>@T("Action")</th>
                          <th>@T("Name")</th>
                        <th>@T("Result")</th>
                        <th>@T("Details")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.Dashboard.AuditLogs)
                    {
                        <tr>
                              <td>@entry.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                              <td>@entry.Action</td>
                              <td>@(string.IsNullOrWhiteSpace(entry.IndexerName) ? "-" : entry.IndexerName)</td>
                              <td><span class="result-badge @(entry.Succeeded ? "result-ok" : "result-fail")">@(entry.Succeeded ? "OK" : "FAIL")</span></td>
                            <td class="audit-details-cell">@entry.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <nav class="pagination-bar" aria-label="@T("PaginationAuditLabel")">
            <span class="pagination-summary">@string.Format(T("PaginationSummary"), Model.Dashboard.AuditPage, Model.Dashboard.AuditTotalPages, Model.Dashboard.AuditTotalCount)</span>
            <div class="pagination-actions">
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.AuditPage <= 1 ? "disabled" : string.Empty)"
                   asp-route-auditPage="1" asp-route-indexerPage="@Model.Dashboard.IndexerPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">«</a>
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.AuditPage <= 1 ? "disabled" : string.Empty)"
                   asp-route-auditPage="@(Math.Max(1, Model.Dashboard.AuditPage - 1))" asp-route-indexerPage="@Model.Dashboard.IndexerPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">‹</a>
                @foreach (var pageNumber in BuildPageNumbers(Model.Dashboard.AuditPage, Model.Dashboard.AuditTotalPages))
                {
                    if (pageNumber is null)
                    {
                        <span class="pagination-ellipsis">…</span>
                    }
                    else
                    {
                        <a class="btn btn-sm pagination-page @(pageNumber == Model.Dashboard.AuditPage ? "btn-primary" : "btn-outline-light")"
                           asp-route-auditPage="@pageNumber" asp-route-indexerPage="@Model.Dashboard.IndexerPage"
                           asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                           asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">@pageNumber</a>
                    }
                }
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.AuditPage >= Model.Dashboard.AuditTotalPages ? "disabled" : string.Empty)"
                   asp-route-auditPage="@(Math.Min(Model.Dashboard.AuditTotalPages, Model.Dashboard.AuditPage + 1))" asp-route-indexerPage="@Model.Dashboard.IndexerPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">›</a>
                <a class="btn btn-sm btn-outline-light @(Model.Dashboard.AuditPage >= Model.Dashboard.AuditTotalPages ? "disabled" : string.Empty)"
                   asp-route-auditPage="@Model.Dashboard.AuditTotalPages" asp-route-indexerPage="@Model.Dashboard.IndexerPage"
                   asp-route-statusFilter="@Model.Dashboard.Filters.Status" asp-route-protocolFilter="@Model.Dashboard.Filters.Protocol"
                   asp-route-auditDateFilter="@Model.Dashboard.Filters.AuditDate" asp-route-auditActionFilter="@Model.Dashboard.Filters.AuditAction" asp-route-auditResultFilter="@Model.Dashboard.Filters.AuditResult">»</a>
            </div>
        </nav>
    }
</section>
